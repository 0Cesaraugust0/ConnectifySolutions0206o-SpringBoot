# Copia este archivo como application-local.properties.
# Este archivo real está ignorado por Git: no lo subas ni compartas.

# Activa exclusivamente el entorno de PRUEBA.
izipay.enabled=true
izipay.mode=TEST
izipay.currency=PEN

# API REST de Izipay / Mi Cuenta Web (pruebas)
# Usa la URL CreatePayment indicada en la documentación de tu comercio.
izipay.endpoint=
izipay.username=
izipay.password=

# SmartForm JavaScript
izipay.public-key=
izipay.smart-form-script-url=https://static.micuentaweb.pe/static/js/krypton-client/V4.0/stable/kr-payment-form.min.js

# Validación de retorno / IPN
izipay.hmac-sha256-key=
izipay.success-url=http://localhost:8080/payments/izipay/success
izipay.error-url=http://localhost:8080/payments/izipay/error
izipay.cancel-url=http://localhost:8080/payments/izipay/cancel

# La URL de notificación debe ser HTTPS y públicamente alcanzable.
# En local, no uses localhost como URL de IPN.
izipay.notification-url=
